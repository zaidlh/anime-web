{
  "entities": {
    "AnimeTitle": {
      "title": "AnimeTitle",
      "description": "An anime or drama title",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "english_title": { "type": ["string", "null"] },
        "type": { "type": ["string", "null"] },
        "poster": { "type": ["string", "null"] },
        "story": { "type": ["string", "null"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "source": { "type": "string", "enum": ["animewitcher", "asia2tv"] },
        "episodesBlob": { "type": "string", "description": "JSON stringified episodes array to stay within limits" }
      },
      "required": ["id", "name", "source"]
    }
  },
  "firestore": {
    "titles": {
      "schema": { "$ref": "#/entities/AnimeTitle" },
      "description": "All anime and drama titles"
    }
  }
}
