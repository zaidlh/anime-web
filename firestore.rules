rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return false; // Nobody is admin for now, reads are open, writes are disabled for clients
    }

    // Validation Blueprints
    function isValidAnimeTitle(data) {
      return data.keys().hasAll(['id', 'name', 'source'])
        && data.id is string && data.id.size() <= 200
        && data.name is string && data.name.size() <= 500
        && data.source is string && (data.source == 'animewitcher' || data.source == 'asia2tv')
        && ( !('english_title' in data) || data.english_title == null || (data.english_title is string && data.english_title.size() <= 500) )
        && ( !('type' in data) || data.type == null || (data.type is string && data.type.size() <= 200) )
        && ( !('poster' in data) || data.poster == null || (data.poster is string && data.poster.size() <= 500) )
        && ( !('story' in data) || data.story == null || (data.story is string && data.story.size() <= 50000) )
        && ( !('episodesBlob' in data) || data.episodesBlob == null || (data.episodesBlob is string) );
    }

    match /titles/{titleId} {
      // Allow unrestricted reads for the titles catalogue
      allow read: if isValidId(titleId);
      
      // Writes are strictly disallowed from standard clients (only Firebase Admin SDK can create/update)
      allow create, update, delete: if isAdmin();
    }
  }
}
